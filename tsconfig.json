{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "outDir": "lib",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitOverride": true,
        "noEmitOnError": true,
        "useDefineForClassFields": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true
    },
    "include": ["src"],
    "exclude": ["lib", "test", "node_modules", "scripts"]
}
